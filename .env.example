# Virtual Mail — Supabase (big-oakland-mail project)
NEXT_PUBLIC_SUPABASE_URL=https://tvonyznxsovyudwulmvk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_RAJqdupqgW3Ew6LtDaOvZA_IDOnWKZ7

# Optional: canonical site URL (used for auth email redirects); falls back to request origin
# NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app

# --- Phase 7 (Payments — Stripe). Server-only unless prefixed NEXT_PUBLIC_. ---
# Stripe test-mode keys (Dashboard → Developers → API keys / Webhooks).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Static 9.25% Stripe TaxRate id (our Oakland rate expressed to Stripe — created in 7a).
# Attached to plan + package Checkout line items so hosted Checkout shows tax.
STRIPE_TAX_RATE_ID=txr_xxx

# Supabase service-role key (server-only!). Used by the Stripe webhook and the
# fulfilment-charge server action to write money rows, bypassing RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx

# Shared secret guarding the monthly overage cron route (/api/cron/overage).
CRON_SECRET=change_me

# --- Phase 8 (Notifications — Resend). Server-only. ---
# Resend API key (resend.com -> API Keys). Until this is set, notify() logs 'skipped' and never sends.
RESEND_API_KEY=re_xxx
# Sending identity. Send from a SUBDOMAIN of the brand domain (protects root-domain reputation).
# Verify notifications.oaklandmailbox.com in Resend (SPF/DKIM/DMARC) before this works.
EMAIL_FROM="Oakland Mailbox <hello@notifications.oaklandmailbox.com>"
EMAIL_REPLY_TO=hello@oaklandmailbox.com
